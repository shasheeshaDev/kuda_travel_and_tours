# Localhost or live site for preview mode
SANITY_STUDIO_PREVIEW_URL=http://localhost:3000
SANITY_STUDIO_API_VERSION=2025-02-14
SANITY_STUDIO_PROJECT_ID=your-project-id
SANITY_STUDIO_DATASET=production

# Editor token — required only for running the seed script (pnpm seed)
# Create one at: https://www.sanity.io/manage → API → Tokens → Add API token (Editor)
SANITY_API_WRITE_TOKEN=your-editor-token